# External LLM API for AI explanations (GraphRAG SAR).
# Copy this file to `.env` (same folder) and fill in your key. `.env` is gitignored.
# Any OpenAI-compatible endpoint works (OpenAI, OpenRouter, Azure, local vLLM, ...).

LLM_API_KEY=sk-your-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
